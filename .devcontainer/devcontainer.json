{
  "name": "Alpine Codespace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "root",
  "hostname": "svmnetwork",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--privileged"
  ],
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  }
}
